<!-- 先导页：引导用户填写基本信息 -->
<view class="container">

  <!-- 顶部企鹅悬浮区 -->
  <view class="penguin-wrap">
    <image
      class="penguin-img {{floating ? 'float-anim' : ''}}"
      src="/images/鹅1.png"
      mode="aspectFill"
    />
  </view>

  <!-- 欢迎文字 -->
  <view class="welcome-block">
    <text class="welcome-title">您好，我是小鹅</text>
    <text class="welcome-sub">在开始之前，请先告诉我一些基本信息</text>
  </view>

  <!-- 基本信息表单卡片 -->
  <view class="card">

    <!-- 姓名 -->
    <view class="form-item">
      <text class="label">姓名</text>
      <input
        class="input"
        placeholder="请输入您的姓名"
        placeholder-class="placeholder"
        bindinput="onNameInput"
        value="{{formData.name}}"
      />
    </view>
    <view class="divider" />

    <!-- 性别 -->
    <view class="form-item">
      <text class="label">性别</text>
      <view class="radio-group">
        <view
          class="radio-item {{formData.gender === 'male' ? 'active' : ''}}"
          bindtap="onGenderTap"
          data-val="male"
        >男</view>
        <view
          class="radio-item {{formData.gender === 'female' ? 'active' : ''}}"
          bindtap="onGenderTap"
          data-val="female"
        >女</view>
      </view>
    </view>
    <view class="divider" />

    <!-- 出生年份滑动条 -->
    <view class="form-item form-item-col">
      <view class="label-row">
        <text class="label">出生年份</text>
        <text class="age-hint">{{formData.birthYear}} 年（{{currentAge}} 岁）</text>
      </view>
      <view class="slider-wrap">
        <!-- 左侧年份 -->
        <text class="year-edge">{{yearMin}}</text>
        <!-- 滑动轨道区域 -->
        <view class="slider-track-wrap">
          <slider
            class="year-slider"
            min="{{yearMin}}"
            max="{{yearMax}}"
            value="{{formData.birthYear}}"
            step="1"
            activeColor="#e87840"
            backgroundColor="#f0d8c8"
            block-color="#ffffff"
            block-size="1"
            bindchange="onBirthYearChange"
            bindchanging="onBirthYearChanging"
          />
          <!-- 浮在滑块上的年份圆形按钮 -->
          <view
            class="slider-thumb"
            style="left: calc({{thumbPercent}}% - 52rpx)"
          >
            <text class="thumb-text">{{formData.birthYear}}</text>
          </view>
        </view>
        <!-- 右侧年份 -->
        <text class="year-edge">{{yearMax}}</text>
      </view>
    </view>

  </view>

  <!-- 语音交互按钮 -->
  <view class="voice-section">
    <!-- 阶段提示 -->
    <view class="voice-hint" wx:if="{{voiceHint}}">{{voiceHint}}</view>
    <view
      class="voice-btn {{isRecording ? 'recording' : ''}} {{isRecognizing ? 'recognizing' : ''}}"
      bindtouchstart="onVoiceStart"
      bindtouchend="onVoiceEnd"
      catchtouchmove
    >
      <text class="voice-icon" wx:if="{{!isRecognizing}}">🎤</text>
      <view class="voice-spinner" wx:else></view>
    </view>
    <!-- 语音识别结果输入框 -->
    <view class="voice-result {{voiceText ? 'show' : ''}}" wx:if="{{voiceText || isRecognizing}}">
      <input
        class="voice-result-input"
        value="{{voiceText}}"
        placeholder="识别中..."
        placeholder-class="voice-result-placeholder"
        bindinput="onVoiceTextInput"
        confirm-type="done"
      />
    </view>
  </view>

  <!-- 提交按钮 -->
  <button class="submit-btn" bindtap="onSubmit">开始使用 →</button>

  <!-- 使用须知弹窗遮罩 -->
  <view class="modal-mask {{showModal ? 'show' : ''}}" bindtap="onModalMaskTap">
    <view class="modal-box" catchtap="">
      <text class="modal-title">使用须知</text>
      <view class="modal-content">
        <view class="modal-item">
          <text class="modal-num">1.</text>
          <text class="modal-text">本产品为预防辅助工具，不适用于膝关节炎患者，不能替代专业医疗诊断。</text>
        </view>
        <view class="modal-item">
          <text class="modal-num">2.</text>
          <text class="modal-text">注册即代表你已知晓并同意，因个人操作不当或隐瞒身体状况引发的风险，需由本人自行承担。</text>
        </view>
        <view class="modal-item">
          <text class="modal-num">3.</text>
          <text class="modal-text">你的健康数据将被严格保密，仅用于为你提供个性化运动建议及产品模型优化。</text>
        </view>
      </view>
      <button class="modal-btn" bindtap="onAgree">我已知晓并同意</button>
    </view>
  </view>

</view>
