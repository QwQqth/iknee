/* ===== 全局容器 ===== */
.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #fff5f0 0%, #ffeee6 60%, #ffd6c2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx 60rpx;
  box-sizing: border-box;
}

/* ===== 企鹅悬浮区 ===== */
.penguin-wrap {
  margin-top: 20rpx;
  margin-bottom: 32rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 360rpx;
}

.penguin-img {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  box-shadow: 0 24rpx 48rpx rgba(230, 120, 80, 0.30);
  animation: floating 3s ease-in-out infinite;
}

@keyframes floating {
  0%   { transform: translateY(0);      box-shadow: 0 24rpx 48rpx rgba(230,120,80,0.30); }
  50%  { transform: translateY(-18rpx); box-shadow: 0 40rpx 64rpx rgba(230,120,80,0.18); }
  100% { transform: translateY(0);      box-shadow: 0 24rpx 48rpx rgba(230,120,80,0.30); }
}

/* ===== 欢迎文字 ===== */
.welcome-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.welcome-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #d96c3a;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.welcome-sub {
  font-size: 26rpx;
  color: #b07050;
  letter-spacing: 1rpx;
}

/* ===== 表单卡片 ===== */
.card {
  width: 100%;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 8rpx 40rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 32rpx rgba(210, 100, 60, 0.10);
  margin-bottom: 48rpx;
}

.form-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  min-height: 104rpx;
  padding: 16rpx 0;
}

.divider {
  height: 1rpx;
  background: #f5ebe4;
  margin: 0 -0rpx;
}

.label {
  font-size: 30rpx;
  color: #5a3a28;
  font-weight: 600;
  width: 180rpx;
  flex-shrink: 0;
}

.input {
  flex: 1;
  font-size: 30rpx;
  color: #3a2010;
  text-align: right;
  height: 72rpx;
  line-height: 72rpx;
}

.placeholder {
  color: #cbb8ae;
  font-size: 28rpx;
}

/* ===== 单选按钮组 ===== */
.radio-group {
  flex: 1;
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  gap: 16rpx;
  flex-wrap: wrap;
}

.radio-item {
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #c08060;
  background: #fff0e8;
  border: 2rpx solid #f0c8a8;
  transition: all 0.2s;
}

.radio-item.active {
  background: #e87840;
  color: #ffffff;
  border-color: #e87840;
  font-weight: 600;
}

/* ===== 出生年份滑动条 ===== */
.form-item-col {
  flex-direction: column;
  align-items: stretch;
  padding: 20rpx 0 24rpx;
}

.label-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.age-hint {
  font-size: 26rpx;
  color: #e87840;
  font-weight: 600;
}

.slider-wrap {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
}

.year-edge {
  font-size: 22rpx;
  color: #c8a090;
  flex-shrink: 0;
  width: 68rpx;
  text-align: center;
}

.slider-track-wrap {
  flex: 1;
  position: relative;
  height: 80rpx;
  display: flex;
  align-items: center;
}

.year-slider {
  width: 100%;
  margin: 0;
}

.slider-thumb {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f0844a 0%, #e05a28 100%);
  box-shadow: 0 8rpx 24rpx rgba(224, 90, 40, 0.40);
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  z-index: 10;
  transition: left 0.05s linear;
}

.thumb-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0;
}

/* ===== 语音交互区 ===== */
.voice-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 36rpx;
}

.voice-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f0844a 0%, #e05a28 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(224, 90, 40, 0.35);
}

.voice-btn.recording {
  animation: pulse 1.2s ease-in-out infinite;
}

.voice-btn.recognizing {
  background: linear-gradient(135deg, #f0a878 0%, #e88858 100%);
  animation: none;
}

@keyframes pulse {
  0%   { transform: scale(1);   box-shadow: 0 8rpx 24rpx rgba(224, 90, 40, 0.35), 0 0 0 0 rgba(232, 120, 64, 0.4); }
  50%  { transform: scale(1.08); box-shadow: 0 8rpx 24rpx rgba(224, 90, 40, 0.35), 0 0 0 16rpx rgba(232, 120, 64, 0); }
  100% { transform: scale(1);   box-shadow: 0 8rpx 24rpx rgba(224, 90, 40, 0.35), 0 0 0 0 rgba(232, 120, 64, 0); }
}

.voice-icon {
  font-size: 52rpx;
  filter: brightness(10) grayscale(1);
}

/* 识别中加载圈 */
.voice-spinner {
  width: 44rpx;
  height: 44rpx;
  border: 5rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #ffffff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 对话阶段提示气泡 */
.voice-hint {
  background: #ffffff;
  color: #3a2010;
  font-size: 26rpx;
  padding: 16rpx 28rpx;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(210, 100, 60, 0.10);
  max-width: 80%;
  text-align: center;
}

/* 识别结果输入框 */
.voice-result {
  width: 100%;
  margin-top: 20rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(210, 100, 60, 0.08);
  padding: 0 32rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  opacity: 0;
  transform: translateY(-10rpx);
  transition: opacity 0.25s, transform 0.25s;
}

.voice-result.show {
  opacity: 1;
  transform: translateY(0);
}

.voice-result-input {
  width: 100%;
  font-size: 28rpx;
  color: #3a2010;
  height: 80rpx;
  line-height: 80rpx;
}

.voice-result-placeholder {
  color: #cbb8ae;
  font-size: 26rpx;
}

/* ===== 提交按钮 ===== */
.submit-btn {
  width: 100%;
  height: 100rpx;
  line-height: 1;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(90deg, #f0844a 0%, #e05a28 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 50rpx;
  letter-spacing: 4rpx;
  box-shadow: 0 12rpx 32rpx rgba(224, 90, 40, 0.35);
  border: none;
}

.submit-btn::after {
  border: none;
}

/* ===== 使用须知弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.50);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.25s, visibility 0.25s;
}

.modal-mask.show {
  opacity: 1;
  visibility: visible;
}

.modal-box {
  width: 620rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 56rpx 48rpx 48rpx;
  box-sizing: border-box;
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.15);
  animation: modalIn 0.3s ease-out;
}

@keyframes modalIn {
  from { transform: scale(0.85); opacity: 0; }
  to   { transform: scale(1);    opacity: 1; }
}

.modal-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #3a2010;
  text-align: center;
  margin-bottom: 40rpx;
  letter-spacing: 4rpx;
}

.modal-content {
  margin-bottom: 48rpx;
}

.modal-item {
  display: flex;
  flex-direction: row;
  margin-bottom: 24rpx;
}

.modal-item:last-child {
  margin-bottom: 0;
}

.modal-num {
  font-size: 26rpx;
  color: #e87840;
  font-weight: 700;
  flex-shrink: 0;
  margin-right: 8rpx;
  line-height: 1.7;
}

.modal-text {
  font-size: 26rpx;
  color: #5a3a28;
  line-height: 1.7;
}

.modal-btn {
  width: 100%;
  height: 88rpx;
  line-height: 1;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(90deg, #f0844a 0%, #e05a28 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  letter-spacing: 2rpx;
  box-shadow: 0 8rpx 24rpx rgba(224, 90, 40, 0.30);
  border: none;
}

.modal-btn::after {
  border: none;
}
