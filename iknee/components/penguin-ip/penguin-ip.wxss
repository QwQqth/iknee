/* 小鹅(iKnee) - 小企鹅IP组件样式 */

.penguin-wrapper {
  position: relative;
  display: inline-block;
}

/* 尺寸 */
.penguin-wrapper.small {
  width: 80rpx;
  height: 80rpx;
}

.penguin-wrapper.medium {
  width: 120rpx;
  height: 120rpx;
}

.penguin-wrapper.large {
  width: 200rpx;
  height: 200rpx;
}

/* 企鹅身体 */
.penguin-body {
  width: 100%;
  height: 100%;
}

.penguin-img {
  width: 100%;
  height: 100%;
}

/* 表情气泡 */
.emotion-bubble {
  position: absolute;
  top: -20rpx;
  right: -30rpx;
  background: #fff;
  padding: 12rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #333;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  white-space: nowrap;
  max-width: 280rpx;
  opacity: 0;
  transform: scale(0.8) translateY(10rpx);
  transition: all 0.3s ease;
}

.emotion-bubble.show {
  opacity: 1;
  transform: scale(1) translateY(0);
}

.emotion-bubble::after {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 20rpx;
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-top: 10rpx solid #fff;
}

/* 动画 */
.penguin-action.bounce {
  animation: penguinBounce 0.5s ease infinite;
}

.penguin-action.shake {
  animation: penguinShake 0.3s ease;
}

.penguin-action.float {
  animation: penguinFloat 2s ease-in-out infinite;
}

.penguin-action.celebrate {
  animation: penguinCelebrate 0.5s ease infinite;
}

@keyframes penguinBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-15rpx); }
}

@keyframes penguinShake {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-5deg); }
  75% { transform: rotate(5deg); }
}

@keyframes penguinFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

@keyframes penguinCelebrate {
  0%, 100% { transform: translateY(0) rotate(-3deg); }
  50% { transform: translateY(-20rpx) rotate(3deg); }
}
