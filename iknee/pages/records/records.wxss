/* 小鹅(iKnee) - 训练记录页样式 */

.records-page {
  min-height: 100vh;
  background: var(--bg-primary);
  padding: 32rpx;
}

/* 统计概览 */
.stats-overview {
  display: flex;
  justify-content: space-between;
  background: #fff;
  padding: 24rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary);
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 日期选择 */
.date-tabs {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
}

.date-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: 16rpx;
}

.date-tab.active {
  background: var(--primary);
  color: #fff;
  font-weight: bold;
}

/* 记录列表 */
.records-list {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-left {
  display: flex;
  flex-direction: column;
}

.record-level {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--primary);
  margin-bottom: 4rpx;
}

.record-action {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.record-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.record-stars {
  margin-bottom: 4rpx;
}

.record-stars text {
  font-size: 24rpx;
  opacity: 0.3;
  margin-left: 2rpx;
}

.record-stars text.star-active {
  opacity: 1;
}

.record-score {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.record-date {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
}
