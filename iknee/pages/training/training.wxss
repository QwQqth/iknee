/* 小鹅(iKnee) - 训练页样式 */

.training-page {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: 140rpx;
}

/* 头部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  padding-top: calc(32rpx + env(safe-area-inset-top));
}

.header-left {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.header-right {
  background: var(--primary);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
}

/* 进度条 */
.progress-bar {
  height: 12rpx;
  background: rgba(255, 159, 67, 0.2);
  margin: 0 32rpx;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--primary-light));
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

/* 关卡区域 */
.levels-section {
  padding: 32rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  display: block;
}

/* 关卡网格 */
.levels-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.level-item {
  width: calc(50% - 12rpx);
  display: flex;
  flex-direction: column;
}

.level-item.locked {
  opacity: 0.6;
}

/* 关卡卡片 */
.level-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  position: relative;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s ease;
}

.level-item:active .level-card {
  transform: scale(0.98);
}

.level-card.completed {
  background: linear-gradient(135deg, #fff, #FFF8E7);
  border: 2rpx solid var(--primary-light);
}

.lock-icon {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  font-size: 32rpx;
}

.level-number {
  width: 48rpx;
  height: 48rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.level-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.level-action {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 16rpx;
}

/* 状态 */
.level-status {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.stars {
  display: flex;
  gap: 4rpx;
}

.star {
  font-size: 28rpx;
  opacity: 0.3;
}

.star.earned {
  opacity: 1;
}

.complete-mark {
  width: 36rpx;
  height: 36rpx;
  background: var(--success);
  color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 20rpx;
}

/* 任务描述 */
.level-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
  padding: 0 8rpx;
}

/* 小企鹅提示 */
.penguin-tip {
  position: fixed;
  bottom: 200rpx;
  right: 32rpx;
  display: flex;
  align-items: flex-end;
}

.tip-penguin {
  width: 100rpx;
  height: 100rpx;
  animation: floatUp 2s ease-in-out infinite;
}

.tip-bubble {
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  max-width: 280rpx;
  margin-right: 16rpx;
}

.tip-bubble::after {
  content: '';
  position: absolute;
  right: 100rpx;
  bottom: 20rpx;
  width: 0;
  height: 0;
  border: 12rpx solid transparent;
  border-right-color: #fff;
}

.tip-bubble text {
  font-size: 28rpx;
  color: var(--text-primary);
}

/* TabBar占位 */
.tabbar-placeholder {
  height: 120rpx;
}

@keyframes floatUp {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}
