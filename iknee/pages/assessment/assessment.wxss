/* 小鹅(iKnee) - 测评页样式 */

.assessment-page {
  min-height: 100vh;
  background: var(--bg-primary);
  padding: 32rpx;
  padding-bottom: 60rpx;
}

/* 说明卡片 */
.info-card {
  display: flex;
  background: #fff;
  padding: 32rpx;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.info-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.info-content {
  flex: 1;
}

.info-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.info-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* 评分区域 */
.score-section {
  background: linear-gradient(135deg, var(--primary), #FFB366);
  padding: 32rpx;
  border-radius: 24rpx;
  margin-bottom: 32rpx;
}

.score-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.score-date {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.score-display {
  display: flex;
  align-items: center;
}

.score-ring {
  width: 150rpx;
  height: 150rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 32rpx;
}

.score-num {
  font-size: 64rpx;
  font-weight: bold;
  color: #fff;
}

.score-info {
  flex: 1;
}

.score-level {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.score-advice {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 开始按钮 */
.start-section {
  text-align: center;
  margin-bottom: 48rpx;
}

.start-btn {
  width: 100%;
  margin-bottom: 16rpx;
}

.start-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 测评项目 */
.test-items {
  margin-bottom: 32rpx;
}

.item-list {
  margin-top: 20rpx;
}

.item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.item-num {
  width: 48rpx;
  height: 48rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.item-content {
  flex: 1;
}

.item-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.item-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 注意事项 */
.notice-section {
  background: #fff;
  padding: 24rpx;
  border-radius: 16rpx;
}

.notice-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.notice-text {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 2;
}
