/* 小鹅(iKnee) - 引导页样式 */

.guide-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F4FD 0%, #D4EAF7 50%, #C5E1F5 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx 60rpx;
  position: relative;
  overflow: hidden;
}

/* 背景雪花装饰 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
}

.snowflake {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  animation: snowfall 3s ease-in-out infinite;
}

.snowflake-1 { left: 10%; top: 20%; animation-delay: 0s; }
.snowflake-2 { left: 80%; top: 30%; animation-delay: 1s; }
.snowflake-3 { left: 50%; top: 15%; animation-delay: 2s; }

@keyframes snowfall {
  0%, 100% { transform: translateY(0) rotate(0deg); opacity: 0.8; }
  50% { transform: translateY(20rpx) rotate(180deg); opacity: 0.4; }
}

/* 小企鹅 */
.penguin-container {
  position: relative;
  width: 280rpx;
  height: 280rpx;
  margin-bottom: 40rpx;
}

.penguin {
  width: 100%;
  height: 100%;
  animation: floatUp 2s ease-in-out infinite;
}

.emotion-bubble {
  position: absolute;
  top: -20rpx;
  right: -40rpx;
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #333;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  opacity: 0;
  transform: scale(0.8) translateY(10rpx);
  transition: all 0.3s ease;
  max-width: 280rpx;
}

.emotion-bubble.show {
  opacity: 1;
  transform: scale(1) translateY(0);
}

.emotion-bubble::after {
  content: '';
  position: absolute;
  bottom: -12rpx;
  left: 30rpx;
  width: 0;
  height: 0;
  border-left: 12rpx solid transparent;
  border-right: 12rpx solid transparent;
  border-top: 12rpx solid #fff;
}

/* 欢迎文字 */
.welcome-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.welcome-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.welcome-subtitle {
  display: block;
  font-size: 32rpx;
  color: #666;
  line-height: 1.5;
}

/* 语音交互区域 */
.voice-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  justify-content: center;
  width: 100%;
}

/* 语音按钮 */
.voice-btn {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF9F43, #FFB366);
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(255, 159, 67, 0.4);
  transition: all 0.2s ease;
  margin-bottom: 40rpx;
}

.voice-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 16rpx rgba(255, 159, 67, 0.3);
}

.voice-btn.recording {
  background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
  animation: pulse 1s ease infinite;
}

.voice-btn.loading {
  background: linear-gradient(135deg, #54A0FF, #74B9FF);
}

.voice-btn-inner {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.mic-icon {
  width: 60rpx;
  height: 60rpx;
}

/* 脉冲动画 */
.pulse-ring {
  position: absolute;
  width: 140rpx;
  height: 140rpx;
  border: 4rpx solid #FF6B6B;
  border-radius: 50%;
  animation: pulseRing 1s ease-out infinite;
}

@keyframes pulseRing {
  0% { transform: scale(1); opacity: 1; }
  100% { transform: scale(1.5); opacity: 0; }
}

/* 加载圈 */
.loading-ring {
  position: absolute;
  width: 140rpx;
  height: 140rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* 识别文字 */
.recognized-text {
  font-size: 32rpx;
  color: #333;
  background: #fff;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  margin-bottom: 24rpx;
  min-height: 80rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  opacity: 0;
  transition: opacity 0.3s ease;
  text-align: center;
}

.recognized-text.show {
  opacity: 1;
}

/* 语音提示 */
.voice-hint {
  font-size: 28rpx;
  color: #FF9F43;
  text-align: center;
  opacity: 0;
  transform: translateY(10rpx);
  transition: all 0.3s ease;
}

.voice-hint.show {
  opacity: 1;
  transform: translateY(0);
}

/* 跳过按钮 */
.skip-btn {
  position: absolute;
  top: 60rpx;
  right: 30rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  color: #666;
}

.skip-btn:active {
  opacity: 0.6;
}

/* 动画 */
@keyframes floatUp {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-15rpx); }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
