/* 小鹅(iKnee) - 百科页样式 */

.encyclopedia-page {
  min-height: 100vh;
  background: var(--bg-primary);
  padding-bottom: 140rpx;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #fff;
}

.search-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: var(--bg-primary);
  border-radius: 36rpx;
  font-size: 28rpx;
}

.search-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 16rpx;
}

/* 分类导航 */
.category-nav {
  white-space: nowrap;
  padding: 24rpx 0;
  background: #fff;
}

.category-item {
  display: inline-block;
  padding: 16rpx 32rpx;
  margin: 0 16rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-radius: 30rpx;
  background: var(--bg-primary);
}

.category-item.active {
  background: var(--primary);
  color: #fff;
}

/* 区块 */
.section {
  padding: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.section-more {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 视频列表 */
.video-scroll {
  white-space: nowrap;
}

.video-card {
  display: inline-block;
  width: 280rpx;
  margin-right: 20rpx;
  vertical-align: top;
}

.video-cover {
  position: relative;
  width: 280rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f0f0f0;
}

.video-cover image {
  width: 100%;
  height: 100%;
}

.video-duration {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  background: rgba(0, 0, 0, 0.6);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.video-duration text {
  font-size: 22rpx;
  color: #fff;
}

.video-info {
  padding: 12rpx 0;
}

.video-title {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.video-views {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* 文章列表 */
.article-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.article-item {
  display: flex;
  background: #fff;
  padding: 20rpx;
  border-radius: 16rpx;
}

.article-cover {
  width: 180rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background: #f0f0f0;
}

.article-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.article-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-meta {
  display: flex;
  align-items: center;
}

.article-tag {
  font-size: 22rpx;
  color: var(--primary);
  background: rgba(255, 159, 67, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.article-date {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* TabBar占位 */
.tabbar-placeholder {
  height: 120rpx;
}
