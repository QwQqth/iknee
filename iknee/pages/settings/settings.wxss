/* 小鹅(iKnee) - 设置页样式 */

.settings-page {
  min-height: 100vh;
  background: var(--bg-primary);
  padding: 32rpx;
}

/* 设置区块 */
.setting-section {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.section-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  padding: 24rpx 32rpx 12rpx;
  background: #fafafa;
}

/* 设置项 */
.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-label {
  font-size: 30rpx;
  color: var(--text-primary);
}

.setting-arrow {
  font-size: 28rpx;
  color: var(--text-disabled);
}

.setting-value {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.picker-value {
  font-size: 28rpx;
  color: var(--primary);
}

/* 滑块 */
slider {
  width: 300rpx;
}

/* 退出按钮 */
.logout-btn {
  margin: 40rpx 0;
}

/* 版本信息 */
.version {
  text-align: center;
  padding: 40rpx;
}

.version text {
  display: block;
  font-size: 24rpx;
  color: var(--text-disabled);
  margin-bottom: 8rpx;
}
