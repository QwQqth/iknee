<!-- 小鹅(iKnee) - 我的页面 -->
<view class="profile-page">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-info">
      <view class="user-avatar">
        <image src="{{userInfo.avatar || '/assets/images/default-avatar.png'}}" mode="aspectFill" />
      </view>
      <view class="user-detail">
        <text class="user-name">{{userInfo.name || '未设置'}}</text>
        <text class="user-title">{{userInfo.gender || ''}} {{userInfo.age ? userInfo.age + '岁' : ''}}</text>
      </view>
    </view>
    <view class="user-stats">
      <view class="stat-item">
        <text class="stat-num">{{stats.totalDays}}</text>
        <text class="stat-label">训练天数</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{stats.totalStars}}</text>
        <text class="stat-label">获得星星</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{stats.avgScore}}</text>
        <text class="stat-label">平均评分</text>
      </view>
    </view>
  </view>

  <!-- 快捷功能 -->
  <view class="quick-section">
    <view class="quick-item" bindtap="onAssessment">
      <view class="quick-icon assessment">
        <text>📋</text>
      </view>
      <text class="quick-text">膝关节测评</text>
    </view>
    <view class="quick-item" bindtap="onRecords">
      <view class="quick-icon records">
        <text>📊</text>
      </view>
      <text class="quick-text">训练记录</text>
    </view>
    <view class="quick-item" bindtap="onBind">
      <view class="quick-icon bind">
        <text>👨‍👩‍👧</text>
      </view>
      <text class="quick-text">家人绑定</text>
    </view>
    <view class="quick-item" bindtap="onSettings">
      <view class="quick-icon settings">
        <text>⚙️</text>
      </view>
      <text class="quick-text">设置</text>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="onHealthRecord">
      <text class="menu-icon">📁</text>
      <text class="menu-text">健康档案</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onBindChild">
      <text class="menu-icon">👶</text>
      <text class="menu-text">子女绑定</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onHelp">
      <text class="menu-icon">❓</text>
      <text class="menu-text">使用帮助</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="onAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>小鹅抗腿队 v1.0.0</text>
  </view>

  <!-- TabBar占位 -->
  <view class="tabbar-placeholder"></view>
</view>
