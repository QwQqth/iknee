<!-- 小鹅(iKnee) - 问答页 -->
<view class="qa-page">
  <!-- 小企鹅 -->
  <view class="qa-header">
    <view class="penguin">
      <image src="/assets/images/penguin/penguin-qa.png" mode="aspectFit" />
    </view>
    <view class="qa-bubble">
      <text>您好，我是小鹅！有什么关于膝关节健康的问题想问我的吗？</text>
    </view>
  </view>

  <!-- 问题建议 -->
  <view class="suggestions">
    <text class="suggestions-title">您可能想问：</text>
    <view class="suggestion-tags">
      <view 
        class="tag"
        wx:for="{{suggestions}}"
        wx:key="id"
        bindtap="onSuggestionTap"
        data-question="{{item.question}}"
      >
        {{item.text}}
      </view>
    </view>
  </view>

  <!-- 输入区 -->
  <view class="input-section">
    <input 
      class="question-input"
      placeholder="输入您的问题..."
      bindconfirm="onSubmitQuestion"
    />
    <button class="submit-btn" bindtap="onSubmitQuestion">
      <text>发送</text>
    </button>
  </view>
</view>
