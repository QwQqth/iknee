/* 小鹅(iKnee) - 全局样式
   腾讯公益项目「企鹅抗腿队」
   适老化大字体设计
*/

/* ========== CSS变量 ========== */
page {
  /* 主色调 - 温暖活力 */
  --primary: #FF9F43;
  --primary-light: #FECA57;
  --primary-dark: #E88A2E;

  /* 辅助色 - 背景 */
  --bg-primary: #E8F4FD;
  --bg-secondary: #F5F9FC;
  --bg-white: #FFFFFF;

  /* 功能色 */
  --success: #26DE81;
  --warning: #FECA57;
  --error: #FF6B6B;
  --info: #54A0FF;

  /* 文字色 */
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-disabled: #999999;
  --text-white: #FFFFFF;

  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;

  /* 圆角 */
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 32rpx;
  --radius-full: 50%;

  /* 阴影 */
  --shadow-sm: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  --shadow-md: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  --shadow-lg: 0 12rpx 36rpx rgba(0, 0, 0, 0.16);

  /* 字体大小 - 适老化 */
  --font-xs: 28rpx;    /* 14pt */
  --font-sm: 32rpx;    /* 16pt */
  --font-md: 36rpx;    /* 18pt */
  --font-lg: 40rpx;    /* 20pt */
  --font-xl: 44rpx;    /* 22pt */
  --font-xxl: 48rpx;   /* 24pt */
  --font-title: 56rpx;  /* 28pt */

  /* 行高 */
  --line-height: 1.6;
}

/* ========== 全局重置 ========== */
page {
  background-color: var(--bg-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: var(--font-lg);
  line-height: var(--line-height);
  color: var(--text-primary);
}

view, text, image, button, input, textarea {
  box-sizing: border-box;
}

/* ========== 文字 ========== */
.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-disabled { color: var(--text-disabled); }
.text-white { color: var(--text-white); }
.text-center { text-align: center; }
.text-bold { font-weight: bold; }

/* 文字尺寸 */
.text-xs { font-size: var(--font-xs); }
.text-sm { font-size: var(--font-sm); }
.text-md { font-size: var(--font-md); }
.text-lg { font-size: var(--font-lg); }
.text-xl { font-size: var(--font-xl); }
.text-xxl { font-size: var(--font-xxl); }
.text-title { font-size: var(--font-title); }

/* ========== 布局 ========== */
.flex { display: flex; }
.flex-row { display: flex; flex-direction: row; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; justify-content: center; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }

/* 居中 */
.center { text-align: center; justify-content: center; align-items: center; }
.center-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

/* ========== 间距 ========== */
.p-xs { padding: var(--spacing-xs); }
.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }
.p-lg { padding: var(--spacing-lg); }
.p-xl { padding: var(--spacing-xl); }

.m-xs { margin: var(--spacing-xs); }
.m-sm { margin: var(--spacing-sm); }
.m-md { margin: var(--spacing-md); }
.m-lg { margin: var(--spacing-lg); }
.m-xl { margin: var(--spacing-xl); }

/* ========== 按钮 ========== */
.btn {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 88rpx;
  padding: 0 48rpx;
  font-size: var(--font-xl);
  font-weight: bold;
  border-radius: var(--radius-lg);
  border: none;
  outline: none;
  transition: all 0.2s ease;
}

.btn::after {
  border: none;
}

/* 主按钮 - 橙色 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary), #FFB366);
  color: var(--text-white);
  box-shadow: 0 8rpx 24rpx rgba(255, 159, 67, 0.4);
}

.btn-primary:active {
  transform: scale(0.95);
  opacity: 0.9;
}

/* 次要按钮 - 白色 */
.btn-secondary {
  background: var(--bg-white);
  color: var(--primary);
  border: 2rpx solid var(--primary);
}

.btn-secondary:active {
  background: var(--bg-primary);
  transform: scale(0.95);
}

/* 成功按钮 - 绿色 */
.btn-success {
  background: linear-gradient(135deg, var(--success), #3AE68A);
  color: var(--text-white);
  box-shadow: 0 8rpx 24rpx rgba(38, 222, 129, 0.4);
}

/* 大按钮 */
.btn-large {
  height: 96rpx;
  font-size: var(--font-xxl);
  padding: 0 64rpx;
}

/* 按钮热区扩展 */
.btn-hotspot {
  padding: 30rpx;
  margin: -30rpx;
}

/* ========== 卡片 ========== */
.card {
  background: var(--bg-white);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-sm);
}

.card-primary {
  background: linear-gradient(135deg, var(--primary), #FFB366);
  color: var(--text-white);
}

/* ========== 输入框 ========== */
.input {
  width: 100%;
  height: 88rpx;
  padding: 0 var(--spacing-md);
  font-size: var(--font-lg);
  background: var(--bg-white);
  border: 2rpx solid #E0E0E0;
  border-radius: var(--radius-md);
  outline: none;
}

.input:focus {
  border-color: var(--primary);
}

.input-placeholder {
  color: var(--text-disabled);
  font-size: var(--font-lg);
}

/* ========== 分割线 ========== */
.divider {
  height: 1rpx;
  background: #E5E5E5;
  margin: var(--spacing-md) 0;
}

.divider-vertical {
  width: 1rpx;
  background: #E5E5E5;
  margin: 0 var(--spacing-md);
}

/* ========== 徽章 ========== */
.badge {
  display: inline-flex;
  justify-content: center;
  align-items: center;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 12rpx;
  font-size: var(--font-xs);
  font-weight: bold;
  background: var(--error);
  color: var(--text-white);
  border-radius: 18rpx;
}

/* ========== 加载动画 ========== */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: var(--spacing-xl);
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--bg-secondary);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ========== 空状态 ========== */
.empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: var(--spacing-xl);
  color: var(--text-secondary);
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: var(--spacing-lg);
  opacity: 0.5;
}

.empty-text {
  font-size: var(--font-lg);
  text-align: center;
}

/* ========== 安全区域 ========== */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.safe-area-top {
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

/* ========== 动画 ========== */
/* 淡入 */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.fade-in {
  animation: fadeIn 0.3s ease;
}

/* 弹跳 */
@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.bounce {
  animation: bounce 1s ease infinite;
}

/* 脉冲 */
@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.1); opacity: 0.8; }
}

.pulse {
  animation: pulse 1.5s ease infinite;
}

/* 上浮 */
@keyframes floatUp {
  0% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
  100% { transform: translateY(0); }
}

.float-up {
  animation: floatUp 2s ease infinite;
}

/* 摇晃(用于错误提示) */
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  20%, 60% { transform: translateX(-10rpx); }
  40%, 80% { transform: translateX(10rpx); }
}

.shake {
  animation: shake 0.5s ease;
}

/* 缩放进入 */
@keyframes scaleIn {
  from { transform: scale(0.8); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.scale-in {
  animation: scaleIn 0.3s ease;
}

/* ========== 隐藏滚动条 ========== */
.hide-scrollbar {
  -webkit-overflow-scrolling: touch;
}

.hide-scrollbar::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
}

/* ========== 遮罩层 ========== */
.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.mask-white {
  background: rgba(255, 255, 255, 0.9);
}

/* ========== 页面容器 ========== */
.page-container {
  min-height: 100vh;
  background: var(--bg-primary);
  padding: var(--spacing-md);
  padding-bottom: calc(var(--spacing-xl) + 120rpx);
}

/* ========== 字体图标 ========== */
/* 使用Unicode字符作为简单图标 */
.icon {
  font-family: "Segoe UI Symbol", "Apple Symbols", sans-serif;
  font-size: 1.2em;
}

.icon-star::before { content: "⭐"; }
.icon-heart::before { content: "❤️"; }
.icon-check::before { content: "✓"; }
.icon-close::before { content: "✕"; }
.icon-arrow::before { content: "→"; }
.icon-arrow-left::before { content: "←"; }
.icon-arrow-up::before { content: "↑"; }
.icon-arrow-down::before { content: "↓"; }
